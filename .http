@baseUrl = http://localhost:3000

### Get all profiles
GET {{baseUrl}}/profiles

### Get a single profile
GET {{baseUrl}}/profiles/214932b8-b93b-41a1-bbb4-a17c4a60849a

### Create profile
POST {{baseUrl}}/profiles
Content-Type: application/json

{
    "name": "adams",
    "description": "proper software developer"
}

### Update profile
PUT {{baseUrl}}/profiles/1 
Content-Type: application/json

{
    "name": "king",
    "description": "badass"
}

### Delete profile 
DELETE {{baseUrl}}/profiles/1
