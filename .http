@baseUrl = http://localhost:3000

### Get all profiles
GET {{baseUrl}}/profiles

### Get a single profile
GET {{baseUrl}}/profiles/214932b8-b93b-41a1-bbb4-a17c4a60849a

### Create profile
POST {{baseUrl}}/profiles
Content-Type: application/json

{
    "name": "adams",
    "description": "proper software developer"
}

### Update profile
PUT {{baseUrl}}/profiles/e8656342-0bbf-40c0-8734-90c886cc2d8e
Content-Type: application/json

{
    "name": "king",
    "description": "badass"
}

### Delete profile 
DELETE {{baseUrl}}/profiles/3e8c8bd9-b7f9-4f79-9658-a3455d3ba8f6
