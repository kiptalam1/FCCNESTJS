@baseUrl = http://localhost:3000

### Get all profiles
GET {{baseUrl}}/profiles?location=bomet

### Get a single profile
GET {{baseUrl}}/profiles/1

### Create profile
POST {{baseUrl}}/profiles
Content-Type: application/json

{
    "name": "adams",
    "description": "proper software developer"
}

### Update profile
PUT {{baseUrl}}/profiles/1 
Content-Type: application/json

{
    "name": "king",
    "description": "badass"
}
